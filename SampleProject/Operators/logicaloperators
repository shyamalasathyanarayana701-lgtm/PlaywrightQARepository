/*
    Logical Operators: (All Logical operators output is Boolean value)
*/
 
let x,y
x=15;y=10
 
//and operator example
console.log("And Operator Example:"+((x>y) && (y<x)));
 
//or operator example
console.log("OR Operator Example:"+(x<y) || (y<x));
 
//Not operator
let isStatus=false
console.log(!isStatus);
 
 